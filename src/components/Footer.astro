---
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark text-gray-400 py-10 border-t-2 border-brand-blue">
  <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 text-center">
    <div class="flex items-center justify-center mb-4">
      <img src="/logos/PhillyBowl_Wordmark_FullColor_LightBackground.png" alt="Philly Bowl" class="h-8" />
    </div>
    <p class="text-sm font-body">
      High School Club Lacrosse Championship
    </p>
    <p class="text-xs mt-3 text-gray-500">
      &copy; {year} Philly Bowl. All rights reserved.
    </p>
  </div>
</footer>
