---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Rules" description="Tournament rules for the Philly Bowl Championship — coming soon.">
  <section class="relative py-32 bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark via-brand-dark/90 to-brand-blue/20"></div>
    <div class="relative z-10 mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-subhead text-brand-light-blue tracking-[0.2em] text-sm mb-4 uppercase">Tournament Guidelines</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl text-white mb-6">Rules</h1>
    </div>
  </section>

  <section class="py-32 bg-white">
    <div class="mx-auto max-w-[600px] px-4 text-center">
      <div class="w-20 h-20 rounded-full bg-brand-blue/10 flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <h2 class="text-3xl md:text-4xl text-brand-dark mb-4">Coming Soon</h2>
      <div class="w-16 h-1 bg-brand-blue mx-auto mb-8 rounded-full"></div>
      <p class="text-brand-gray max-w-md mx-auto">
        Tournament rules and regulations will be published here ahead of the event. All participating teams will be notified when the rules are finalized.
      </p>
    </div>
  </section>
</BaseLayout>
