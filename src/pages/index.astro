---
import BaseLayout from '../layouts/BaseLayout.astro';
import teamsData from '../data/teams.json';
const { divisions } = teamsData;

const teamLogos = [
  '/images/teams/3D Upstate.svg',
  '/images/teams/BPG.svg',
  '/images/teams/Brotherly Love.svg',
  '/images/teams/DUKESELITE.svg',
  '/images/teams/Freedom.svg',
  '/images/teams/NATIONS_BEST.svg',
  '/images/teams/TEAM TEN.svg',
  '/images/teams/UPSTATE UNION.svg',
  '/images/teams/XLC.svg',
  '/images/teams/dc_express.svg',
  '/images/teams/hilltop_lax.svg',
];


---

<BaseLayout title="Home">
  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-brand-dark">
    <img src="/images/PHILLY_BOWL_BANNER.png" alt="" class="absolute inset-0 w-full h-full object-cover" />

    <div class="relative z-10 px-6 sm:px-10 lg:px-16 max-w-[1280px] mx-auto w-full">
      <div class="max-w-xl">
        <p class="text-brand-light-blue tracking-[0.2em] text-xs md:text-sm mb-4 uppercase" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">High School Club Lacrosse</p>
        <h1 class="text-3xl sm:text-4xl md:text-[2.8rem] text-white leading-[0.95] mb-6 whitespace-nowrap" style="text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
          The Philly Bowl<br/>Championship
        </h1>
        <p class="text-white/80 text-base md:text-lg leading-relaxed max-w-md mb-8">
          A boutique championship event designed for maximum college exposure. The Philly Bowl brings together the best club programs in the country for a premier recruiting experience at WSFS Sports Complex.
        </p>
        <a
          href="#details"
          class="inline-block bg-brand-blue hover:bg-brand-light-blue text-white uppercase tracking-wider text-sm px-8 py-3 rounded transition-colors duration-200"
        >
          Event Details
        </a>
      </div>
    </div>
  </section>

  <!-- LOGO CAROUSEL -->
  <section class="bg-white py-6 overflow-hidden">
    <div class="flex items-center carousel-track" style="width: max-content;">
      {[...teamLogos, ...teamLogos].map((logo) => (
        <img src={logo} alt="" class="h-14 mx-8 object-contain" loading="lazy" />
      ))}
    </div>
  </section>

  <!-- EVENT DETAILS -->
  <section id="details" class="py-20 bg-brand-dark">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 lg:px-16">
      <!-- Section header - left aligned -->
      <p class="text-brand-blue tracking-[0.2em] text-xs mb-3 uppercase" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">July 17, 2026 &middot; WSFS Sports Complex</p>
      <h2 class="text-3xl md:text-4xl text-white mb-14">Event Details</h2>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: icon + text rows -->
        <div class="space-y-8">
          <!-- Date -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-brand-blue shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <div>
              <p class="text-white text-lg" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">July 17th, 2026</p>
              <p class="text-brand-gray text-xs uppercase tracking-widest mt-1" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Date</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-brand-blue shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p class="text-white text-lg" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">WSFS Sports Complex</p>
              <p class="text-brand-gray text-xs uppercase tracking-widest mt-1" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Location</p>
            </div>
          </div>

          <!-- Divisions -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-brand-blue shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <div>
              <p class="text-white text-lg" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">2027, 2028, 2029</p>
              <p class="text-brand-gray text-xs uppercase tracking-widest mt-1" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Divisions</p>
            </div>
          </div>

          <!-- Fields -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-brand-blue shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M12 7v14M2 14h20"/></svg>
            <div>
              <p class="text-white text-lg" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">3 Fields</p>
              <p class="text-brand-gray text-xs uppercase tracking-widest mt-1" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">2 Back-to-Back for Recruiting Year Games</p>
            </div>
          </div>
        </div>

        <!-- Right: logo + stat cards -->
        <div class="flex flex-col items-center -mt-6">
          <img src="/logos/philly_logo.png" alt="Philly Bowl" class="h-44 md:h-52 mb-4 object-contain" />
        <div class="grid grid-cols-3 gap-4 w-full">
          <div class="border border-gray-600 rounded-lg p-6 text-center">
            <p class="text-4xl md:text-5xl text-brand-blue mb-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">3</p>
            <p class="text-white/70 text-xs uppercase tracking-wider mt-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Divisions</p>
            <p class="text-brand-gray text-xs mt-1">2027 &middot; 2028 &middot; 2029</p>
          </div>
          <div class="border border-gray-600 rounded-lg p-6 text-center">
            <p class="text-4xl md:text-5xl text-brand-blue mb-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">8</p>
            <p class="text-white/70 text-xs uppercase tracking-wider mt-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Teams / Div</p>
            <p class="text-brand-gray text-xs mt-1">Elite Programs</p>
          </div>
          <div class="border border-gray-600 rounded-lg p-6 text-center">
            <p class="text-4xl md:text-5xl text-brand-blue mb-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">3</p>
            <p class="text-white/70 text-xs uppercase tracking-wider mt-2" style="font-family: 'DDC Hardware', 'Arial Black', sans-serif;">Games Min</p>
            <p class="text-brand-gray text-xs mt-1">Championship Format</p>
          </div>
        </div>
        </div>
      </div>

      <!-- Schedule button -->
      <div class="text-center mt-14">
        <a
          href="#"
          class="inline-block bg-brand-blue hover:bg-brand-light-blue text-white uppercase tracking-wider text-sm px-10 py-3 rounded transition-colors duration-200"
        >
          View Schedule on Tourney Machine
        </a>
      </div>
    </div>
  </section>

  <!-- TEAMS ATTENDING -->
  <section class="py-20 bg-brand-off-white">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 lg:px-16">
      <h2 class="text-3xl md:text-4xl text-brand-dark mb-6">Teams Attending</h2>

      <div class="flex gap-2 mb-10" role="tablist" aria-label="Division tabs">
        {divisions.map((div, i) => (
          <button
            class="division-tab px-6 py-2 text-sm font-subhead uppercase tracking-wider rounded border border-brand-gray/30 transition-colors duration-200"
            data-tab={i}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${i}`}
          >
            {div.name}
          </button>
        ))}
      </div>

      {divisions.map((div, i) => (
        <div
          id={`panel-${i}`}
          class="division-panel"
          role="tabpanel"
          data-panel={i}
          style={i !== 0 ? 'display:none' : ''}
        >
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
            {div.teams.map((team) => (
              <div class="bg-white rounded-lg border border-gray-200 aspect-square flex items-center justify-center p-4 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
                <img
                  src={team.logo}
                  alt={team.name}
                  class="w-[70%] h-[70%] object-contain"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  // Division Tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.division-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.division-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = tab.dataset.tab;

      tabs.forEach(t => {
        t.setAttribute('aria-selected', 'false');
        t.classList.remove('bg-brand-blue', 'text-white', 'border-brand-blue');
      });

      tab.setAttribute('aria-selected', 'true');
      tab.classList.add('bg-brand-blue', 'text-white', 'border-brand-blue');

      panels.forEach(p => {
        p.style.display = p.dataset.panel === idx ? '' : 'none';
      });
    });
  });

  tabs[0]?.classList.add('bg-brand-blue', 'text-white', 'border-brand-blue');


</script>
